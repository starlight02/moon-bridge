# MoonBridge E2E Test Configuration
#
# Copy this file to .env.test and fill in your API keys.
# The e2e test loader walks up from the working directory to find .env.test.
# OS-level env vars take precedence over values in this file.

# OpenAI Chat E2E (internal/e2e/openai_chat_e2e_test.go)
TEST_OPENAI_API_KEY=sk-your-key-here
# TEST_OPENAI_BASE_URL=https://api.openai.com
# TEST_OPENAI_MODEL=gpt-4o-mini

# Anthropic E2E (internal/e2e/anthropic_e2e_test.go)
# TEST_ANTHROPIC_API_KEY=sk-ant-your-key-here
# TEST_ANTHROPIC_BASE_URL=https://api.anthropic.com
# TEST_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google GenAI E2E (internal/e2e/google_genai_e2e_test.go)
# TEST_GEMINI_API_KEY=your-key-here
# TEST_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# TEST_GEMINI_MODEL=gemini-2.0-flash
# TEST_GEMINI_PROJECT=  # GCP project ID (Vertex AI only)
# TEST_GEMINI_LOCATION=  # GCP location (Vertex AI only)
# TEST_GEMINI_VERSION=v1beta

# OpenAI Responses Passthrough E2E (internal/e2e/openai_response_e2e_test.go)
# TEST_OPENAI_RESPONSE_API_KEY=sk-your-key-here
# TEST_OPENAI_RESPONSE_BASE_URL=https://api.openai.com
